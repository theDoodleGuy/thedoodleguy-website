---
layout: base.njk
permalink: /blog/
metaTitle: "Blog — AI adaptation strategies for designers"
description: "Adaptation strategies, AI tools worth knowing about, and true career stories for designers navigating the AI wave."
---

<header class="page-head">
  <div class="mono eyebrow">// the blog</div>
  <h1 class="display">Field notes from the <span class="hl">AI wave</span></h1>
  <p class="hero-sub">Adaptation strategies, tech worth knowing about, and true stories from a career
     designer — now product manager — figuring out the next wave in public.</p>
  <div class="filters" role="group" aria-label="Filter posts by topic">
    <button class="chip chip-on" data-filter="All">All</button>
    <button class="chip" data-filter="Adaptation">Adaptation</button>
    <button class="chip" data-filter="Tech Advances">Tech Advances</button>
    <button class="chip" data-filter="Past Experience">Past Experience</button>
  </div>
</header>

<section class="post-grid wide">
  {% for post in collections.posts %}
  <article class="post-card" data-pillar="{{ post.data.pillar }}">
    <div class="post-meta mono">
      <span class="tag tag-{{ post.data.pillar | replace(' ', '') | lower }}">{{ post.data.pillar }}</span>
      <span>{{ post.date | readableDate }} · {{ post.data.readTime }}</span>
    </div>
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <p>{{ post.data.excerpt }}</p>
    <a class="hand read-more" href="{{ post.url }}">read it →</a>
  </article>
  {% endfor %}
</section>

{% include "newsletter.njk" %}

<script>
  document.querySelectorAll('.chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
      document.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('chip-on'); });
      chip.classList.add('chip-on');
      var filter = chip.dataset.filter;
      document.querySelectorAll('.post-card[data-pillar]').forEach(function (card) {
        card.style.display = (filter === 'All' || card.dataset.pillar === filter) ? '' : 'none';
      });
    });
  });
</script>
